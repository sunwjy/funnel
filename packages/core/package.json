{
  "name": "@sunwjy/funnel-core",
  "version": "0.1.0",
  "description": "Core types, plugin interface, and dispatcher for the funnel marketing event tracking library",
  "keywords": [
    "analytics",
    "tracking",
    "funnel",
    "ga4",
    "marketing",
    "event-tracking"
  ],
  "author": "sunwjy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunwjy/funnel.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sunwjy/funnel#readme",
  "bugs": {
    "url": "https://github.com/sunwjy/funnel/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.0",
    "typescript": "^6.0.2"
  }
}
